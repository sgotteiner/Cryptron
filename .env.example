# Database — Postgres connection string (memory layer 1).
# Supabase: Settings → Database → Connection string (URI). Local Postgres works too.
DATABASE_URL=postgresql://user:password@host:5432/postgres

# Telegram sense (reading groups via Telethon) — from https://my.telegram.org
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_PHONE_NUMBER=+972501234567

# CMC sense (market snapshots) — free key from https://pro.coinmarketcap.com
CMC_API_KEY=your_cmc_key
# Twitter/X sense (attention) — your X account; twikit logs in with it
TWITTER_USERNAME=your_handle
TWITTER_EMAIL=you@example.com
TWITTER_PASSWORD=your_password

# --- Not needed yet (later slices) ---
# TELEGRAM_BOT_TOKEN=your_bot_token      # notifications (the voice)
# TELEGRAM_CHAT_ID=your_chat_id
# GEMINI_API_KEY=AIza...                 # LLM (the investigator)
# GROQ_API_KEY=gsk_...
# OPENROUTER_API_KEY=sk-or-v1-...